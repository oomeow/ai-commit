#compdef ai-commit

autoload -U is-at-least

_ai-commit() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-f+[Use a custom config file]:FILE:_files' \
'--config=[Use a custom config file]:FILE:_files' \
'-p+[Use a specific configured provider for this run]:NAME:_default' \
'--provider=[Use a specific configured provider for this run]:NAME:_default' \
'-a[Stage all changes before generating the commit message]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_ai-commit_commands" \
"*::: :->ai-commit" \
&& ret=0
    case $state in
    (ai-commit)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:ai-commit-command-$line[1]:"
        case $line[1] in
            (install)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(uninstall)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(commit)
_arguments "${_arguments_options[@]}" : \
'--output-file=[Write generated message to file]:FILE:_files' \
'-p+[Use a specific configured provider for this run]:NAME:_default' \
'--provider=[Use a specific configured provider for this run]:NAME:_default' \
'-a[Stage all changes before generating the commit message]' \
'--add[Stage all changes before generating the commit message]' \
'--dry-run[Show generated message without committing]' \
'--generate-only[Generate commit message only (no commit, no confirmation)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(amend)
_arguments "${_arguments_options[@]}" : \
'-p+[Use a specific configured provider for this run]:NAME:_default' \
'--provider=[Use a specific configured provider for this run]:NAME:_default' \
