'--help[Print help]' \
&& ret=0
;;
(provider)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
":: :_ai-commit__subcmd__config__subcmd__provider_commands" \
"*::: :->provider" \
&& ret=0

    case $state in
    (provider)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:ai-commit-config-provider-command-$line[1]:"
        case $line[1] in
            (list)
