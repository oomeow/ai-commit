#!/bin/sh
# ai-commit prepare-commit-msg hook
# Automatically generates AI commit messages for Git commits

COMMIT_MSG_FILE="$1"
COMMIT_SOURCE="$2"
SHA1="$3"

# Skip for merge, squash, or template commits (only run for normal commits)
if [ "$COMMIT_SOURCE" != "" ] && [ "$COMMIT_SOURCE" != "message" ]; then
    exit 0
fi

# Require ai-commit to be available; if not, skip silently
if ! command -v ai-commit >/dev/null 2>&1; then
    echo "ai-commit not found. Skipping AI commit message generation." >&2
    exit 0
fi

# Generate AI commit message
# Use `commit --generate-only` for pure message output
if generated_msg=$(ai-commit commit --generate-only 2>/dev/null); then
    # Check if we got a non-empty message
    if [ -n "$generated_msg" ]; then
        # Write the generated message to the commit message file
        echo "$generated_msg" > "$COMMIT_MSG_FILE"
        echo "AI-generated commit message applied." >&2
    else
        echo "AI generated empty message. Using original message." >&2
    fi
else
    # If ai-command fails (no staged changes, API error, etc.)
    # Silently continue with original commit message
    echo "Failed to generate AI commit message. Using original message." >&2
fi

exit 0
